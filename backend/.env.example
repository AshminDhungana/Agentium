# ═══════════════════════════════════════════════════════════════════════════════
# Agentium — Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
# Generate fresh secrets with: python ./scripts/gen_secrets.py
# ═══════════════════════════════════════════════════════════════════════════════

# ── CORS / Security ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Secret key for JWT signing (generate a new one for production)
SECRET_KEY=your-secret-key-here

# Encryption key for sensitive data (generate a new one for production)
ENCRYPTION_KEY=your-encryption-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://agentium:agentium@postgres:5432/agentium

# --- Connection pool tuning (production load) ---
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ── Vector Store ──────────────────────────────────────────────────────────────
# ChromaDB connection
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Cache / Message Bus ───────────────────────────────────────────────────────
# Redis connection string
REDIS_URL=redis://redis:6379/0

# ── Celery ───────────────────────────────────────────────────────────────────
# Celery broker and result backend (uses Redis by default)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Object Storage (MinIO / S3-compatible) ────────────────────────────────────
# MinIO credentials (used for object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# S3-compatible endpoint and bucket
S3_ENDPOINT=http://minio:9000
S3_BUCKET_NAME=agentium-media

# AWS credentials (falls back to MinIO credentials if not set)
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER:-minioadmin}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD:-minioadmin}

# ── Voice Bridge ──────────────────────────────────────────────────────────────
# Secret for Voice WebSocket JWT tokens
VOICE_JWT_SECRET=your-voice-jwt-secret

# Token duration for voice bridge sessions (minutes)
VOICE_TOKEN_DURATION_MINUTES=30

# ── Federation ────────────────────────────────────────────────────────────────
# Enable federation between Agentium instances
FEDERATION_ENABLED=false
FEDERATION_INSTANCE_NAME=Agentium-Primary
FEDERATION_INSTANCE_URL=https://your-agentium.example.com
FEDERATION_SHARED_SECRET=your-federation-secret

# ── External APIs ─────────────────────────────────────────────────────────────
# Search APIs (leave blank to use DuckDuckGo as fallback)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_KEY=

# Financial data (leave blank to use yfinance, which needs no key)
STOCK_API_KEY=
DEFAULT_BROKER_EMAIL=broker@yourdomain.com

# ── Testing ───────────────────────────────────────────────────────────────────
# Set to True during test runs (disables external AI provider calls)
TESTING=False
