# Root environment example for `docker compose`.
# Copy to `.env` and fill in. Any variable left blank falls back to the
# default shown in docker-compose.yml (e.g. MinIO -> minioadmin/minioadmin).
# This file is committed; `.env` is gitignored and must NOT be committed.

# --- MinIO (object storage) ---
# Left blank -> Compose defaults to minioadmin / minioadmin.
# If set, the value must match across the MinIO server and all S3 clients.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
