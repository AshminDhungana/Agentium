{
  "ci": {
    "collect": {
      "url": ["http://localhost:4173/"],
      "startServerCommand": "npm run preview -- --port 4173 --host",
      "startServerReadyPattern": "Local.*http",
      "numberOfRuns": 3
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.50 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],

        "unused-css-rules": ["warn", { "maxLength": 0 }],
        "unused-javascript": ["warn", { "maxLength": 0 }],
        "non-composited-animations": ["warn", { "minScore": 0.9 }],
        "lcp-lazy-loaded": ["warn", { "minScore": 0.9 }],
        "prioritize-lcp-image": ["warn", { "minScore": 0.9 }],
        "modern-image-formats": ["warn", { "maxLength": 0 }],
        "mainthread-work-breakdown": ["warn", { "minScore": 0.9 }],
        "max-potential-fid": ["warn", { "minScore": 0.9 }],
        "first-contentful-paint": ["warn", { "minScore": 0.9 }],
        "interactive": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "minScore": 0.9 }],

        "errors-in-console": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
